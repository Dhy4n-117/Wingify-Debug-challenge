# ========================================
# Financial Document Analyzer — Environment Variables
# ========================================
# Copy this file to .env and fill in your API keys.
# At minimum, you need GEMINI_API_KEY to run the analysis.

# --- LLM Configuration ---
# Google Gemini (default — free tier available at https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here
MODEL_NAME=gemini/gemini-2.0-flash

# --- Search Tool ---
# Serper.dev API key for web search (free tier at https://serper.dev)
SERPER_API_KEY=your_serper_api_key_here

# --- Database ---
# SQLite is used by default (no config needed). Override for other databases:
# DATABASE_URL=sqlite:///./financial_analyzer.db

# --- Queue Worker (Optional — for async processing) ---
# Redis URL for Celery message broker
# REDIS_URL=redis://localhost:6379/0
